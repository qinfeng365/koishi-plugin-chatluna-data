{
    "compilerOptions": {
        "module": "esnext",
        "target": "es2022",
        "emitDeclarationOnly": true,
        "declaration": true,
        "composite": true,
        "incremental": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "strictNullChecks": false,
        "moduleResolution": "bundler",
        "rootDir": "src",
        "outDir": "lib"
    },
    "include": [
        "src"
    ]
}
